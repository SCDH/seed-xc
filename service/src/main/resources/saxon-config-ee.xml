     https://www.saxonica.com/documentation10/#!configuration/configuration-file
     and adapted.
-->
<configuration xmlns="http://saxon.sf.net/ns/configuration"
               edition="EE"
	       licenseFileLocation="/etc/licenses/saxon-license.lic"
               label="Hardened configuration">
  <global
    allowedProtocols=""
    allowExternalFunctions="false"
    unparsedTextURIResolver="de.ulbms.scdh.seed.xc.harden.DenyingResourceResolver"
    uriResolver="de.ulbms.scdh.seed.xc.harden.DenyingResourceResolver"
    xpathVersionForXsd="20"
    xpathVersionForXslt="31"
    />

  <xslt
    outputUriResolver="de.ulbms.scdh.seed.xc.harden.DenyingOutputURIResolver"
    />

</configuration>
